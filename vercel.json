{
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "framework": null,
  "routes": [
    { "src": "^/$", "dest": "/landing.html" },
    { "src": "^/privacy$", "dest": "/privacy.html" },
    { "src": "^/play$", "dest": "/index.html" },
    {
      "src": "^/_expo/static/(.*)",
      "dest": "/_expo/static/$1",
      "headers": { "cache-control": "public, max-age=31536000, immutable" }
    },
    {
      "src": "^/(ads\\.txt|robots\\.txt|favicon\\.png|apple-touch-icon\\.png|og-image\\.png|google[a-z0-9]+\\.html|privacy\\.html|landing\\.html)$",
      "dest": "/$1"
    },
    { "src": "^/(.*)", "dest": "/index.html" }
  ]
}
